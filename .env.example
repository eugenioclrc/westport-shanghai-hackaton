# WestPort.ai environment

# --- Database (Vercel / production) ---------------------------------------
# Create a Turso DB:  turso db create westport && turso db show westport --url
#                     turso db tokens create westport
# Leave BOTH unset locally to use the bundled file DB (backend/westport.sqlite).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth ------------------------------------------------------------------
# REQUIRED in prod (ENV=prod). App refuses to boot with the dev default.
JWT_SECRET=

# --- Environment -----------------------------------------------------------
ENV=dev            # dev | prod

# --- LLM provider (pick one; omit all to run in mock mode) -----------------
# LLM_MOCK=1
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# OPENROUTER_API_KEY=
# ORBIT_API_KEY=
# LLM_PROVIDER=
# LLM_MODEL_AGENT=
# LLM_MODEL_ORCHESTRATOR=
# LLM_BASE_URL=
