{
  "name": "westport-ai",
  "version": "0.1.0",
  "description": "WestPort.ai compliance navigator for Chinese hardware entering EU markets",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node backend/index.js",
    "dev:api": "node backend/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node backend/index.js",
    "seed": "node backend/seed.js",
    "db:push": "node backend/scripts/db-push.js",
    "corpus:build": "node backend/scripts/build-corpus.js",
    "test": "node --test backend/tests/*.test.js",
    "audit": "pnpm audit --audit-level=moderate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@libsql/client": "0.17.3",
    "@lucide/svelte": "1.16.0",
    "cors": "2.8.5",
    "express": "5.2.1",
    "express-rate-limit": "7.2.0",
    "jsonwebtoken": "9.0.2",
    "node-fetch": "3.3.2",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "20.19.41",
    "svelte": "5.55.7",
    "vite": "8.0.13"
  }
}
